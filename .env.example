# Copy to a file OUTSIDE the repo (we use ~/.config/trinity/secrets.env) and
# `source` it before running. NEVER put real values in a file inside this repo.
#
#   cp .env.example ~/.config/trinity/secrets.env   # then fill in + chmod 600
#   source ~/.config/trinity/secrets.env

# === REQUIRED for evaluation ===
# OpenRouter — serves the three coordinated LLMs
# (qwen3.5-35b-a3b, gemini-3.1-flash-lite, deepseek-v4-flash)
export OPENROUTER_API_KEY="sk-or-v1-xxx_your_key_here"

# === REQUIRED (maintainer only — for building hidden benchmarks) ===
# AES-256-GCM password for encrypting the hidden benchmark files.
# If lost, the benchmark cannot be decrypted and must be rebuilt.
export BENCHMARK_PASSWORD="strong-secret-password"

# === OPTIONAL (maintainer only — defaults to ../tinyrouter-benchmark/) ===
# Directory for the encrypted hidden benchmark files (eval/audit/live per
# benchmark). Miners do NOT need this — it is maintainer-side only.
# export TINYROUTER_BENCHMARK_DIR="/path/to/tinyrouter-benchmark"